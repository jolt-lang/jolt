  ;; multimethod dispatch cache — behavior the cache (a perf optimization) must
  ;; preserve. Each "after" value can only stay correct if the cache invalidates
  ;; on defmethod / derive / underive / prefer-method / remove-method, so these
  ;; rows guard the invalidation machinery (jolt-mw44.30).
  {:suite "mm-cache" :label "isa?-dispatch via derive (2-level) resolves to the registered method" :expected "[:A :A :A]" :expr "(do (defmulti f (fn [x] x)) (defmethod f :p/a [x] :A) (derive :c/b :p/a) (derive :c/c :c/b) [(f :p/a) (f :c/b) (f :c/c)])"}
  {:suite "mm-cache" :label "a closer ancestor added AFTER the first dispatch wins (defmethod + derive invalidate the cached resolution)" :expected "[:ROOT :MID]" :expr "(do (defmulti f (fn [x] x)) (defmethod f :p/root [x] :ROOT) (derive :c/child :p/root) (let [b (f :c/child)] (derive :p/mid :p/root) (derive :c/child :p/mid) (defmethod f :p/mid [x] :MID) [b (f :c/child)]))"}
  {:suite "mm-cache" :label "underive after the first dispatch falls through to :default (hierarchy mutation invalidates)" :expected "[:A :DEF]" :expr "(do (defmulti f (fn [x] x) :default :d) (defmethod f :p/a [x] :A) (defmethod f :d [x] :DEF) (derive :c/c :p/a) (let [b (f :c/c)] (underive :c/c :p/a) [b (f :c/c)]))"}
  {:suite "mm-cache" :label "prefer-method breaks an isa? tie" :expected ":B" :expr "(do (defmulti f (fn [x] x)) (defmethod f :p/a [x] :A) (defmethod f :p/b [x] :B) (derive :c/c :p/a) (derive :c/c :p/b) (prefer-method f :p/b :p/a) (f :c/c))"}
  {:suite "mm-cache" :label "prefer-method re-resolves a value already cached for the other branch (derive + prefer invalidate)" :expected "[:A :B]" :expr "(do (defmulti f (fn [x] x)) (defmethod f :p/a [x] :A) (defmethod f :p/b [x] :B) (derive :c/c :p/a) (let [b (f :c/c)] (derive :c/c :p/b) (prefer-method f :p/b :p/a) [b (f :c/c)]))"}
  {:suite "mm-cache" :label "remove-method after the first dispatch falls through to :default (remove un-caches)" :expected "[:A :DEF]" :expr "(do (defmulti f (fn [x] x) :default :d) (defmethod f :p/a [x] :A) (defmethod f :d [x] :DEF) (derive :c/c :p/a) (let [b (f :c/c)] (remove-method f :p/a) [b (f :c/c)]))"}
