  {:suite "math-nan" :label "Math/pow neg base fractional exp -> NaN" :expected "##NaN" :expr "(Math/pow -2.0 0.5)"}
  {:suite "math-nan" :label "Math/log negative -> NaN" :expected "##NaN" :expr "(Math/log -1.0)"}
  {:suite "math-nan" :label "Math/asin out of domain -> NaN" :expected "##NaN" :expr "(Math/asin 2.0)"}
